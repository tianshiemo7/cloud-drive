# 管理员密钥（不设置则自动生成，强烈建议手动设置）
CLOUD_DRIVE_ADMIN_KEY=change_me_to_a_strong_key

# 服务端口（默认 3002）
# PORT=3002

# ===== 集群配置（部署时写入，之后不变） =====
# 公网访问地址（对方通过这个地址连接你）
# PUBLIC_ENDPOINT=http://你的公网IP:3002

# 生成集群密钥（部署时执行一次，之后不变）:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CLUSTER_SECRET=把输出的64位hex粘贴到这里

# 节点 ID（建议用 IP 或自定义名称）
# CLUSTER_NODE_ID=node-1
# CLUSTER_NODE_NAME=节点1

# 对等节点列表（集群模式下列出其他节点）
# CLUSTER_PEERS=node-2::http://对方IP:3002::上方生成的密钥

# 超时设置（可选）
# CLUSTER_TIMEOUT=5000
