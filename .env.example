# 管理员密钥（不设置则自动生成）
CLOUD_DRIVE_ADMIN_KEY=change_me_to_a_strong_key

# ===== 集群配置（可选，不配置则为独立模式） =====
# 节点身份
# CLUSTER_NODE_ID=node-1
# CLUSTER_NODE_NAME=节点1
# CLUSTER_SECRET=<和其他节点相同的64位hex>
#
# 对等节点列表（逗号分隔）
# 格式: nodeId::http://ip:port::secret
# CLUSTER_PEERS=node-2::http://192.168.1.10:3002::<secret>
#
# 可选参数
# CLUSTER_TIMEOUT=5000
# CLUSTER_SIGNATURE_WINDOW=300
